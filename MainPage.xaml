<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiApp12.MainPage" BackgroundColor="White">

    <VerticalStackLayout Padding="20" Spacing="15">

        <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
            <Entry x:Name="PoleTekstowe" 
                   Placeholder="Nowy element" 
                   TextColor="Black"
                   WidthRequest="250" />

            <Button x:Name="PrzyciskDodaj"
                    Text="DODAJ"
                    BackgroundColor="#DC143C"
                    TextColor="White"
                    Clicked="KliknieciePrzyciskuDodaj" />
        </HorizontalStackLayout>

        <ListView x:Name="WidokListyNotatek" 
                  SeparatorColor="#DC143C">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <TextCell Text="{Binding .}" TextColor="black" />
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

    </VerticalStackLayout>

</ContentPage>
