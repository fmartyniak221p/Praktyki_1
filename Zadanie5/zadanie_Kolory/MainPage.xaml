<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiApp13.MainPage">

    <VerticalStackLayout Padding="20" Spacing="10">

        <Label Text="Wzornik kolorów RGB. Wykonał [Twój Numer]" 
               HorizontalOptions="Center" />

        <BoxView x:Name="DuzyProstokat"
                 Color="White"
                 HeightRequest="150"
                 WidthRequest="250"
                 HorizontalOptions="Center" />

        <Label Text="Dobierz kolor suwakami i zapisz przyciskiem:" 
               HorizontalOptions="Center" />

        <Grid ColumnDefinitions="20, *, 40" RowDefinitions="Auto, Auto, Auto">
            <Label Grid.Row="0" Grid.Column="0" Text="R" VerticalOptions="Center" />
            <Slider x:Name="SliderR" Grid.Row="0" Grid.Column="1" Minimum="0" Maximum="255" Value="255" ValueChanged="ZmienKolor" />
            <Label x:Name="LabelR" Grid.Row="0" Grid.Column="2" Text="255" VerticalOptions="Center" />

            <Label Grid.Row="1" Grid.Column="0" Text="G" VerticalOptions="Center" />
            <Slider x:Name="SliderG" Grid.Row="1" Grid.Column="1" Minimum="0" Maximum="255" Value="255" ValueChanged="ZmienKolor" />
            <Label x:Name="LabelG" Grid.Row="1" Grid.Column="2" Text="255" VerticalOptions="Center" />

            <Label Grid.Row="2" Grid.Column="0" Text="B" VerticalOptions="Center" />
            <Slider x:Name="SliderB" Grid.Row="2" Grid.Column="1" Minimum="0" Maximum="255" Value="255" ValueChanged="ZmienKolor" />
            <Label x:Name="LabelB" Grid.Row="2" Grid.Column="2" Text="255" VerticalOptions="Center" />
        </Grid>

        <Button Text="Pobierz" 
                BackgroundColor="#CD853F" 
                Clicked="PobierzKolor" 
                HorizontalOptions="Center" />

        <Label x:Name="EtykietaWynik"
               Text="255, 255, 255"
               BackgroundColor="White"
               TextColor="Black"
               HorizontalTextAlignment="Center"
               HeightRequest="50"
               WidthRequest="150"
               HorizontalOptions="Center"
               VerticalTextAlignment="Center" />

    </VerticalStackLayout>

</ContentPage>
